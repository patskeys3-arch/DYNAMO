    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "Id": "f7b30b9f0e774b3bb6fb72bb3e5f17dc",
      "NodeType": "FunctionNode",
      "Inputs": [
        {
          "Id": "5e996a5f8e034b4c959e9a29a0d194ab",
          "Name": "cogoPoint",
          "Description": "Autodesk.Civil.DynamoNodes.CogoPoint",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "130bf0e3a7b54874878c86bf2c33a807",
          "Name": "string",
          "Description": "Raw description of COGO point",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "FunctionSignature": "Autodesk.Civil.DynamoNodes.CogoPoint.RawDescription",
      "Replication": "Auto",
      "Description": "Returns the raw description of a COGO point\n\nCogoPoint.RawDescription: string"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "\"\"\"Dynamo Python helper for HomeINV.\r\n\r\nInputs\r\nIN[0] rim points: DesignScript points or Civil COGO points\r\nIN[1] rim elevations: list[double]\r\nIN[2] invert points: DesignScript points or Civil COGO points\r\nIN[3] invert values: either depth values or UDP dictionaries\r\nIN[4] UDP key: default \"INVERT\"\r\nIN[5] leader dx: default 5.0\r\nIN[6] leader dy: default 5.0\r\nIN[7] text height: default 1.0\r\nIN[8] precision: default 2\r\nIN[9] create leaders: default False\r\n\r\nOutputs\r\nOUT[0] summary per rim\r\nOUT[1] created multileader count\r\nOUT[2] errors\r\n\"\"\"\r\n\r\nimport math\r\n\r\n\r\ndef _flatten(value):\r\n    if isinstance(value, (list, tuple)):\r\n        out = []\r\n        for item in value:\r\n            out.extend(_flatten(item))\r\n        return out\r\n    return [value]\r\n\r\n\r\ndef _as_list(value):\r\n    if value is None:\r\n        return []\r\n    if isinstance(value, (list, tuple)):\r\n        return list(value)\r\n    return [value]\r\n\r\n\r\ndef _maybe_float(value):\r\n    if value is None:\r\n        return None\r\n    if isinstance(value, bool):\r\n        return float(value)\r\n    if isinstance(value, (int, float)):\r\n        return float(value)\r\n    if isinstance(value, str):\r\n        cleaned = value.strip()\r\n        if not cleaned:\r\n            return None\r\n        filtered = \"\".join(ch for ch in cleaned if ch in \"0123456789.-\")\r\n        if filtered in (\"\", \"-\", \".\", \"-.\"):\r\n            return None\r\n        try:\r\n            return float(filtered)\r\n        except Exception:\r\n            return None\r\n    return None\r\n\r\n\r\ndef _dict_value(item, key):\r\n    if item is None:\r\n        return None\r\n    if isinstance(item, dict):\r\n        return item.get(key)\r\n    if hasattr(item, \"ValueAtKey\"):\r\n        try:\r\n            return item.ValueAtKey(key)\r\n        except Exception:\r\n            pass\r\n    if hasattr(item, \"__getitem__\"):\r\n        try:\r\n            return item[key]\r\n        except Exception:\r\n            pass\r\n    return item\r\n\r\n\r\ndef _extract_depth(item, key):\r\n    value = _dict_value(item, key)\r\n    flat = _flatten(value)\r\n    for candidate in flat:\r\n        number = _maybe_float(candidate)\r\n        if number is not None:\r\n            return number\r\n    return None\r\n\r\n\r\ndef _point_xyz(item):\r\n    if item is None:\r\n        return None\r\n    if all(hasattr(item, axis) for axis in (\"X\", \"Y\")):\r\n        z = getattr(item, \"Z\", 0.0)\r\n        return (float(item.X), float(item.Y), float(z))\r\n    if all(hasattr(item, axis) for axis in (\"Easting\", \"Northing\")):\r\n        z = getattr(item, \"Elevation\", 0.0)\r\n        return (float(item.Easting), float(item.Northing), float(z))\r\n    if hasattr(item, \"PointGeometry\"):\r\n        geom = item.PointGeometry\r\n        if geom and all(hasattr(geom, axis) for axis in (\"X\", \"Y\")):\r\n            z = getattr(geom, \"Z\", 0.0)\r\n            return (float(geom.X), float(geom.Y), float(z))\r\n    return None\r\n\r\n\r\ndef _format_number(value, precision):\r\n    return (\"{0:.\" + str(int(precision)) + \"f}\").format(float(value))\r\n\r\n\r\ndef _build_text(rim_elev, invert_elevs, precision):\r\n    lines = [\"RIM ELEV = \" + _format_number(rim_elev, precision)]\r\n    for elev in sorted(invert_elevs, reverse=True):\r\n        lines.append(\"INVERT ELEV = \" + _format_number(elev, precision))\r\n    return lines\r\n\r\n\r\ndef _distance_xy(a, b):\r\n    dx = a[0] - b[0]\r\n    dy = a[1] - b[1]\r\n    return dx * dx + dy * dy\r\n\r\n\r\nrim_points = _as_list(IN[0] if len(IN) > 0 else None)\r\nrim_elevs = _as_list(IN[1] if len(IN) > 1 else None)\r\ninvert_points = _as_list(IN[2] if len(IN) > 2 else None)\r\ninvert_values = _as_list(IN[3] if len(IN) > 3 else None)\r\nudp_key = IN[4] if len(IN) > 4 and IN[4] else \"INVERT\"\r\nleader_dx = float(IN[5]) if len(IN) > 5 and IN[5] is not None else 5.0\r\nleader_dy = float(IN[6]) if len(IN) > 6 and IN[6] is not None else 5.0\r\ntext_height = float(IN[7]) if len(IN) > 7 and IN[7] is not None else 1.0\r\nprecision = int(IN[8]) if len(IN) > 8 and IN[8] is not None else 2\r\ncreate_leaders = bool(IN[9]) if len(IN) > 9 else False\r\n\r\nerrors = []\r\nrim_data = []\r\n\r\nfor idx, rim in enumerate(rim_points):\r\n    xyz = _point_xyz(rim)\r\n    elev = rim_elevs[idx] if idx < len(rim_elevs) else None\r\n    elev = _maybe_float(elev if elev is not None else (xyz[2] if xyz else None))\r\n    if xyz is None or elev is None:\r\n        errors.append(\"Skipped rim index {0}: missing point or elevation.\".format(idx))\r\n        continue\r\n    rim_data.append(\r\n        {\r\n            \"index\": idx,\r\n            \"xyz\": xyz,\r\n            \"elev\": elev,\r\n            \"invertElevs\": [],\r\n        }\r\n    )\r\n\r\nif not rim_data:\r\n    OUT = ([], 0, errors + [\"No valid rim points were supplied.\"])\r\nelse:\r\n    for idx, inv_point in enumerate(invert_points):\r\n        inv_xyz = _point_xyz(inv_point)\r\n        depth_source = invert_values[idx] if idx < len(invert_values) else None\r\n        depth = _extract_depth(depth_source, udp_key)\r\n        if inv_xyz is None or depth is None:\r\n            errors.append(\"Skipped invert index {0}: missing point or {1} value.\".format(idx, udp_key))\r\n            continue\r\n        nearest = min(rim_data, key=lambda rim: _distance_xy(inv_xyz, rim[\"xyz\"]))\r\n        nearest[\"invertElevs\"].append(nearest[\"elev\"] - depth)\r\n\r\n    summary = []\r\n    for rim in rim_data:\r\n        lines = _build_text(rim[\"elev\"], rim[\"invertElevs\"], precision)\r\n        summary.append(\r\n            {\r\n                \"rimPoint\": rim[\"xyz\"],\r\n                \"rimElevation\": rim[\"elev\"],\r\n                \"invertElevations\": sorted(rim[\"invertElevs\"], reverse=True),\r\n                \"textLines\": lines,\r\n                \"mtextContents\": \"\\\\P\".join(lines),\r\n                \"leaderPoint\": (rim[\"xyz\"][0] + leader_dx, rim[\"xyz\"][1] + leader_dy, rim[\"xyz\"][2]),\r\n            }\r\n        )\r\n\r\n    created_count = 0\r\n\r\n    if create_leaders:\r\n        try:\r\n            import clr\r\n\r\n            for assembly_name in (\"AcMgd\", \"AcDbMgd\", \"AcCoreMgd\"):\r\n                try:\r\n                    clr.AddReference(assembly_name)\r\n                except Exception:\r\n                    pass\r\n\r\n            from Autodesk.AutoCAD.ApplicationServices import Application\r\n            from Autodesk.AutoCAD.DatabaseServices import BlockTableRecord, ContentType, MLeader, MText, OpenMode\r\n            from Autodesk.AutoCAD.Geometry import Point3d\r\n\r\n            doc = Application.DocumentManager.MdiActiveDocument\r\n            db = doc.Database\r\n            lock_doc = doc.LockDocument()\r\n            tr = db.TransactionManager.StartTransaction()\r\n\r\n            try:\r\n                block_table = tr.GetObject(db.BlockTableId, OpenMode.ForRead)\r\n                model_space = tr.GetObject(block_table[BlockTableRecord.ModelSpace], OpenMode.ForWrite)\r\n\r\n                for item in summary:\r\n                    mleader = MLeader()\r\n                    mleader.SetDatabaseDefaults()\r\n                    mleader.ContentType = ContentType.MTextContent\r\n\r\n                    mtext = MText()\r\n                    mtext.SetDatabaseDefaults()\r\n                    mtext.TextHeight = text_height\r\n                    mtext.Contents = item[\"mtextContents\"]\r\n                    mtext.Location = Point3d(\r\n                        item[\"leaderPoint\"][0], item[\"leaderPoint\"][1], item[\"leaderPoint\"][2]\r\n                    )\r\n\r\n                    mleader.MText = mtext\r\n                    mleader.TextLocation = Point3d(\r\n                        item[\"leaderPoint\"][0], item[\"leaderPoint\"][1], item[\"leaderPoint\"][2]\r\n                    )\r\n                    mleader.AddLeaderLine(Point3d(item[\"rimPoint\"][0], item[\"rimPoint\"][1], item[\"rimPoint\"][2]))\r\n\r\n                    model_space.AppendEntity(mleader)\r\n                    tr.AddNewlyCreatedDBObject(mleader, True)\r\n                    created_count += 1\r\n\r\n                tr.Commit()\r\n            finally:\r\n                tr.Dispose()\r\n                lock_doc.Dispose()\r\n        except Exception as ex:\r\n            errors.append(\"Leader creation failed: {0}\".format(ex))\r\n\r\n    OUT = (summary, created_count, errors)\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "05de4b3031d44ffc99a2dfa5ac22851d",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "e34e42de76e04214b7aa478841a3d3a2",
